# ============================================================
# AKSRAYA HEALTH CARE - SEO & Security Configuration
# ============================================================

# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Remove www prefix to enforce non-www domain (301 redirect)
    RewriteCond %{HTTP_HOST} ^www\.aksrayahealthcare\.com$ [NC]
    RewriteRule ^(.*)$ https://aksrayahealthcare.com/$1 [R=301,L]

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remove trailing slashes (optional, but good for consistency)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([^/]+)/$ /$1 [R=301,L]

    # Prevent direct access to certain files
    RewriteRule ^(generate_terms\.py|remove_bg\.py|SERVICE CONSENT FORM\.txt)$ - [F]

</IfModule>

# ============================================================
# HTTP Headers for SEO and Performance
# ============================================================

<IfModule mod_headers.c>
    # Cache Control for static assets
    <FilesMatch "\.(?:jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Cache HTML for 1 day (allows updates)
    <FilesMatch "\.html?$">
        Header set Cache-Control "public, must-revalidate, max-age=86400"
    </FilesMatch>

    # Add security headers
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Allow Google to index pages
    Header always edit Content-Security-Policy ^(.*)$
    
    # Prevent caching of redirects
    <FilesMatch "\.php$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>

# ============================================================
# Compression for Performance
# ============================================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
</IfModule>

# ============================================================
# File Type Handling
# ============================================================

# Prevent access to hidden files and directories
<FilesMatch "^\.|\.gz$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Allow direct access to specific files
<FilesMatch "\.(html?|css|js|json|svg|woff2?|ttf|eot)$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</FilesMatch>

# ============================================================
# Sitemap & Robots
# ============================================================

# Ensure robots.txt and sitemap.xml are always accessible
<FilesMatch "^(robots\.txt|sitemap\.xml)$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</FilesMatch>
